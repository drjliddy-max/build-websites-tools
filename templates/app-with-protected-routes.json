{
  "_description": "Starting gate.config.json for a marketing site that also hosts an authenticated app section (e.g. /dashboard, /settings, /app). The authenticated routes go in allowClientOnlyRoutes so gate-seo does not demand server-rendered HTML for them. Marketing routes stay in routes and ARE gated.",
  "routes": [
    "/",
    "/about",
    "/features",
    "/pricing",
    "/contact",
    "/privacy",
    "/terms",
    "/accessibility",
    "/login",
    "/signup"
  ],
  "baseUrl": "http://127.0.0.1:3000",
  "launchCommand": "npm run dev -- --hostname 127.0.0.1 --port 3000",
  "startupTimeoutMs": 60000,
  "allowedOffSitemapRoutes": [
    "/login",
    "/signup",
    "/thank-you"
  ],
  "productionSeo": {
    "requireServerRenderedHtml": true,
    "minServerRenderedTextChars": 300,
    "allowClientOnlyRoutes": [
      "/dashboard",
      "/settings",
      "/app"
    ],
    "requiredHealthPaths": [],
    "requiredApiDependencyPaths": [],
    "requireHtmlCacheControl": false,
    "requireStaticAssetCacheControl": false,
    "requireSecurityHeaders": false
  },
  "aiInstrumentation": {
    "ga4": {
      "consentGated": { "measurementId": "G-CHANGE-ME" }
    }
  }
}
