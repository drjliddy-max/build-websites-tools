{
  "_description": "Starting gate.config.json for a marketing + blog site. Lists the blog index plus each published post route explicitly so gate-seo verifies every post returns 200 with proper meta. Add a route per published post; do not rely on a wildcard.",
  "routes": [
    "/",
    "/about",
    "/contact",
    "/privacy",
    "/terms",
    "/accessibility",
    "/blog",
    "/blog/example-post-slug-1",
    "/blog/example-post-slug-2"
  ],
  "baseUrl": "http://127.0.0.1:3000",
  "launchCommand": "npm run dev -- --hostname 127.0.0.1 --port 3000",
  "startupTimeoutMs": 60000,
  "productionSeo": {
    "requireServerRenderedHtml": true,
    "minServerRenderedTextChars": 400,
    "requiredHealthPaths": [],
    "requiredApiDependencyPaths": [],
    "requireHtmlCacheControl": false,
    "requireStaticAssetCacheControl": false,
    "requireSecurityHeaders": false
  },
  "aiInstrumentation": {
    "ga4": {
      "consentGated": { "measurementId": "G-CHANGE-ME" }
    }
  }
}
