{
  "_description": "Starting gate.config.json for a marketing site (homepage + service/product pages + required legal). Copy, adjust 'routes' for the actual pages, and set baseUrl. Do not remove /privacy, /terms, /accessibility, or /contact — the gate enforces them.",
  "routes": [
    "/",
    "/about",
    "/services",
    "/pricing",
    "/contact",
    "/privacy",
    "/terms",
    "/accessibility"
  ],
  "baseUrl": "http://127.0.0.1:3000",
  "launchCommand": "npm run dev -- --hostname 127.0.0.1 --port 3000",
  "startupTimeoutMs": 60000,
  "productionSeo": {
    "requireServerRenderedHtml": true,
    "minServerRenderedTextChars": 300,
    "requiredHealthPaths": [],
    "requiredApiDependencyPaths": [],
    "requireHtmlCacheControl": false,
    "requireStaticAssetCacheControl": false,
    "requireSecurityHeaders": false
  },
  "aiInstrumentation": {
    "ga4": {
      "consentGated": { "measurementId": "G-CHANGE-ME" }
    }
  }
}
